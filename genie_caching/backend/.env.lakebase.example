# Databricks Lakebase Configuration Example
# Copy to .env and update with your values

# === Application Settings ===
APP_ENV=production
STORAGE_BACKEND=pgvector

# === Databricks Lakebase Connection ===
# Your Databricks email (URL encoding handled automatically)
POSTGRES_USER=user@company.com

# Your PostgreSQL password
POSTGRES_PASSWORD=your_password_here

# Lakebase instance hostname (without postgresql:// prefix)
LAKEBASE_INSTANCE=<instance>.database.<region>.cloud.databricks.com

# Lakebase catalog and schema
LAKEBASE_CATALOG=my_catalog
LAKEBASE_SCHEMA=public

# PostgreSQL settings
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require

# Table name (without catalog.schema prefix)
PGVECTOR_TABLE_NAME=cached_queries

# === Databricks Configuration ===
# For App Auth: Service Principal credentials (automatically provided in Databricks Apps)
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_CLIENT_ID=auto-provided-in-databricks-apps
# DATABRICKS_CLIENT_SECRET=auto-provided-in-databricks-apps

# Genie and SQL Warehouse (can be overridden from frontend)
GENIE_SPACE_ID=your_space_id
SQL_WAREHOUSE_ID=your_warehouse_id

# === Embedding Configuration ===
EMBEDDING_PROVIDER=databricks
DATABRICKS_EMBEDDING_ENDPOINT=databricks-gte-large-en

# === Application Settings ===
MAX_QUERIES_PER_MINUTE=5
SIMILARITY_THRESHOLD=0.85

# === Connection String Format ===
# The application builds this automatically:
# postgresql://user%40company.com:password@<instance>.database.<region>.cloud.databricks.com:5432/databricks_postgres?sslmode=require

# === Full Table Name ===
# The application uses: my_catalog.public.cached_queries
