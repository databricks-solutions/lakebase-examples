# Environment Configuration
APP_ENV=development  # development or production

# Storage Backend — Lakebase (pgvector) only
STORAGE_BACKEND=pgvector

# === PostgreSQL + PGVector (STORAGE_BACKEND=pgvector) ===
# Connection details for PostgreSQL with pgvector extension
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DATABASE=genie_cache
PGVECTOR_TABLE_NAME=cached_queries

# === Databricks Configuration ===
# In Databricks Apps: DATABRICKS_HOST, DATABRICKS_CLIENT_ID, and
# DATABRICKS_CLIENT_SECRET are auto-injected. Do NOT set these manually.
# For local development: set DATABRICKS_HOST and use OAuth (databricks auth login).
# NEVER use Personal Access Tokens (dapi...).
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# When true (default), Genie, SQL Warehouse, and embedding (Model Serving) calls use the
# app's OAuth service principal (DATABRICKS_CLIENT_ID/SECRET), not the end-user JWT.
# Set false for local dev if you rely on passthrough user tokens only.
AUTH_USE_APP_SERVICE_PRINCIPAL=true

# Databricks Unity Catalog settings
CATALOG_NAME=main
SCHEMA_NAME=genie_cache
CACHE_TABLE_NAME=query_cache

# Databricks Genie & SQL Warehouse (can be overridden from frontend)
GENIE_SPACE_ID=your_space_id_here
SQL_WAREHOUSE_ID=your_warehouse_id_here

# Genie REST identity:
# Leave unset or false (default) so Genie uses the signed-in user's OAuth token from
# Databricks Apps (X-Forwarded-Access-Token).
# Set to true only when the workspace requires the app's service principal for Genie
# (bindings on the SP). SQL Warehouse still uses the user token unless the statements
# API returns 403 and the app retries with SP.
GENIE_FORCE_APP_SERVICE_PRINCIPAL=false

# Per-gateway caching can be toggled when creating gateways; global default is on.
# To disable semantic cache for all gateways that inherit the default, add a row in
# global_settings (Settings API) for key "caching_enabled": false.
# Provider: databricks or local
EMBEDDING_PROVIDER=databricks

# Databricks embedding endpoint
# Common endpoints: databricks-gte-large-en
DATABRICKS_EMBEDDING_ENDPOINT=databricks-gte-large-en

# Model Serving / embeddings often reject the Apps user JWT ("model-serving" OAuth scope).
# false (default): try user token first, then one automatic retry with app SP if scope denied.
# true: always use app service principal for embeddings (requires DATABRICKS_CLIENT_ID/SECRET).
EMBEDDING_FORCE_APP_SERVICE_PRINCIPAL=false

# Local embedding model (if EMBEDDING_PROVIDER=local)
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# === Application Settings ===
MAX_QUERIES_PER_MINUTE=5
SIMILARITY_THRESHOLD=0.85

# === Important Notes ===
# 1. For PGVector: Ensure PostgreSQL has pgvector extension installed
#    Run: CREATE EXTENSION IF NOT EXISTS vector;
#
# 2. For Databricks Apps: DATABRICKS_HOST, DATABRICKS_CLIENT_ID, 
#    DATABRICKS_CLIENT_SECRET are automatically provided
#
# 3. Frontend settings (Genie Space, Warehouse ID, Auth Mode) 
#    can override these defaults
