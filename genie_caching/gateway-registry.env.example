# Optional: artifact mirror vars for CORPORATE networks (pip / uv only).
#
# NPM is not used — the UI is Plotly Dash (Python). Bootstrap CSS loads from CDN.
#
# Typical usage before `pip install -r backend/requirements.txt`:
#   source ./gateway-registry.env.example   # after editing URLs below
#
# Python / uv
# export UV_INDEX_URL=""
# export PIP_INDEX_URL=""
#
# Internal TLS interception
# export REQUESTS_CA_BUNDLE=""
# export SSL_CERT_FILE=""
